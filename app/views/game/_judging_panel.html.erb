<div class="judging-panel" data-controller="game">
  <h3>Choose the winner</h3>
  <p class="hint">Tap a submission to award the point.</p>

  <div class="submissions-grid">
    <% submissions.each do |submission| %>
      <form action="<%= pick_winner_path(room.code, submission.id) %>"
            data-action="submit->game#pickWinner"
            class="submission-form">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="submission-card">
          <% submission.cards.each do |card| %>
            <span class="submission-card__text"><%= card.content %></span>
          <% end %>
        </button>
      </form>
    <% end %>
  </div>
</div>
