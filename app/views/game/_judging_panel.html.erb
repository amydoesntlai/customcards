<div class="judging-panel" data-controller="game">
  <h3>Choose the winner</h3>
  <p class="hint">Tap a submission to select it, then confirm.</p>

  <div class="submissions-grid">
    <% submissions.each do |submission| %>
      <div class="submission-card"
           data-game-target="submissionCard"
           data-action="click->game#selectSubmission"
           data-pick-url="<%= pick_winner_path(room.code, submission.id) %>">
        <% submission.cards.order("submission_cards.position").each do |card| %>
          <span class="submission-card__text"><%= card.content %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="judging-footer">
    <button class="btn btn--primary"
            data-game-target="confirmBtn"
            data-action="click->game#pickWinner"
            disabled>
      Confirm winner
    </button>
  </div>
</div>
